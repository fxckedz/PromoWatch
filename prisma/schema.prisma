// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id           String   @id @default(uuid())
  externalId   String
  platform     Platform
  title        String
  lastPrice    Decimal
  currentPrice Decimal
  urlOriginal  String   @db.Text
  urlAffiliate String   @db.Text
  isPromo      Boolean  @default(false)
  lastPostedAt DateTime?
  createdAt    DateTime @default(now())

  @@unique([externalId, platform])
}

model PlatformCredential {
  id              String   @id @default(uuid())
  platform        Platform @unique

  // Campos para OAuth (Meli, Shopee)
  accessToken     String?  @db.Text
  refreshToken    String?  @db.Text
  expiresAt       DateTime?

  // Campos para APIs de Chave Fixa (Amazon)
  apiKey          String?  @db.Text
  apiSecret       String?  @db.Text
  associateTag    String?  // Exclusivo da Amazon

  updatedAt       DateTime @updatedAt
}

enum Platform {
  MERCADO_LIVRE
  AMAZON
  SHOPEE
}
