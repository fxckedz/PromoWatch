// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id           String   @id @default(uuid())
  externalId   String   @map("external_id")
  platform     Platform
  title        String
  lastPrice    Decimal  @map("last_price")
  currentPrice Decimal  @map("current_price")
  urlOriginal  String   @db.Text @map("url_original")
  urlAffiliate String   @db.Text @map("url_affiliate")
  isPromo      Boolean  @default(false) @map("is_promo")
  lastPostedAt DateTime? @map("last_posted_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([externalId, platform])
  @@map("products")
}

model Integration {
  id           String    @id @default(uuid())
  platform     Platform  @unique

  // Campos para OAuth
  accessToken  String?   @db.Text @map("access_token")
  refreshToken String?   @db.Text @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")

  // Campos para APIs de Chave Fixa
  apiKey       String?   @db.Text @map("api_key")
  apiSecret    String?   @db.Text @map("api_secret")
  associateTag String?   @map("associate_tag")

  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("integrations")
}

enum Platform {
  MERCADO_LIVRE
  AMAZON
  SHOPEE
}
